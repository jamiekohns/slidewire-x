{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "wendelladriel/slidewire",
    "type": "library",
    "description": "Reveal-style presentations for Laravel using Livewire.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/filesystem": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/view": "^12.0",
        "livewire/flux": "^2.0",
        "livewire/livewire": "^4.0",
        "phiki/phiki": "^2.1",
        "spatie/laravel-pdf": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.24",
        "laravel/framework": "^12.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "WendellAdriel\\SlideWire\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "pint --parallel",
            "rector"
        ],
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:types": [
            "pest --type-coverage --min=100"
        ],
        "test:unit": "pest --parallel --exclude-group=browser",
        "test:browser": "pest --group=browser",
        "test:browser:ci": "pest --group=browser --compact",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "prepare": [
            "@lint",
            "@test"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "WendellAdriel\\SlideWire\\SlideWireServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
