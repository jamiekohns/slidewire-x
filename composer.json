{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "wendelladriel/slidewire",
    "type": "library",
    "description": "Create beautiful presentations powered by Livewire",
    "keywords": [
        "laravel",
        "livewire",
        "presentations",
        "slides",
        "blade"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/filesystem": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/view": "^12.0|^13.0",
        "livewire/livewire": "^4.2",
        "phiki/phiki": "^2.1"
    },
    "require-dev": {
        "laravel/pint": "^1.28",
        "orchestra/testbench": "^10.9",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "WendellAdriel\\SlideWire\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": [
            "pint --parallel",
            "rector"
        ],
        "test:lint": [
            "pint --parallel --test",
            "rector --dry-run"
        ],
        "test:types": [
            "pest --type-coverage --min=100"
        ],
        "test:unit": "pest --parallel --exclude-group=browser",
        "test:browser": "pest --group=browser",
        "test:browser:ci": "pest --group=browser --compact",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "prepare": [
            "@lint",
            "@test"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "WendellAdriel\\SlideWire\\SlideWireServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
